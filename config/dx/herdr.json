{
  "schemaVersion": 1,
  "name": "herdr",
  "scope": "global",
  "configPath": "~/.config/dx/herdr.toml",
  "runtimeDir": "~/.config/herdr",
  "worktreesDir": "~/Projects/herdr-worktrees",
  "skillPath": "~/.config/agents/skills/herdr/SKILL.md",
  "docsPath": "~/.config/dx/herdr.md",
  "minHerdrVersion": "0.7.0",
  "socketPath": "~/.config/herdr/herdr.sock",
  "docs": {
    "home": "https://herdr.dev/docs/",
    "socketApi": "https://herdr.dev/docs/socket-api/",
    "cliReference": "https://herdr.dev/docs/cli-reference/",
    "agents": "https://herdr.dev/docs/agents/",
    "agentsSource": "https://github.com/ogulcancelik/herdr/blob/master/website/src/content/docs/agents.mdx",
    "howToWork": "https://herdr.dev/docs/how-to-work/",
    "howToWorkSource": "https://github.com/ogulcancelik/herdr/blob/master/website/src/content/docs/how-to-work.mdx",
    "configuration": "https://herdr.dev/docs/configuration/",
    "configurationSource": "https://github.com/ogulcancelik/herdr/blob/master/website/src/content/docs/configuration.mdx",
    "integrations": "https://herdr.dev/docs/integrations/",
    "persistenceRemote": "https://herdr.dev/docs/persistence-remote/",
    "persistenceRemoteSource": "https://github.com/ogulcancelik/herdr/blob/master/website/src/content/docs/persistence-remote.mdx",
    "sessionState": "https://herdr.dev/docs/session-state/",
    "sessionStateSource": "https://github.com/ogulcancelik/herdr/blob/master/website/src/content/docs/session-state.mdx",
    "upstreamDocsDir": "https://github.com/ogulcancelik/herdr/tree/master/website/src/content/docs",
    "agentSkill": "https://herdr.dev/docs/agent-skill/"
  },
  "binary": "herdr",
  "shellModule": "~/.config/shell/herdr.sh",
  "maintenanceCommand": "herder-maintain",
  "integrations": {
    "required": ["codex", "kimi", "hermes", "claude", "cursor"],
    "optional": ["pi", "opencode", "copilot", "devin", "droid"]
  },
  "screenDetectedAgents": ["grok"],
  "minIntegrationVersions": {
    "codex": 5,
    "kimi": 3,
    "hermes": 2,
    "claude": 6,
    "cursor": 1
  },
  "spawnWrappers": [
    "~/.local/bin/herdr-spawn-codex",
    "~/.local/bin/herdr-spawn-kimi",
    "~/.local/bin/herdr-spawn-hermes",
    "~/.local/bin/herdr-spawn-grok",
    "~/.local/bin/herdr-spawn-claude"
  ],
  "agentSkills": [
    "~/.grok/skills/herdr",
    "~/.codex/skills/herdr",
    "~/.claude/skills/herdr",
    "~/.kimi-code/skills/herdr",
    "~/.hermes/skills/herdr"
  ],
  "orchestratorSkill": "~/.config/agents/skills/orchestrator/SKILL.md",
  "orchestratorSkills": [
    "~/.grok/skills/orchestrator",
    "~/.codex/skills/orchestrator",
    "~/.claude/skills/orchestrator",
    "~/.kimi-code/skills/orchestrator",
    "~/.hermes/skills/orchestrator"
  ],
  "notifications": {
    "delivery": "system",
    "terminalNotifier": "terminal-notifier"
  },
  "project": {
    "discovery": [".dx/herdr.toml", "dx.config.toml", ".dx/config.toml", ".config/dx.toml"],
    "template": "~/.config/dx/templates/herdr.project.toml",
    "configTemplate": "~/.config/dx/templates/herdr.project.config.toml",
    "tool": "herdr-project"
  }
}